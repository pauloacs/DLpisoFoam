sinclude $(GENERAL_RULES)/module-path-user

/* Failsafe - user location */
ifeq (,$(strip $(FOAM_MODULE_APPBIN)))
    FOAM_MODULE_APPBIN = $(FOAM_USER_APPBIN)
endif
ifeq (,$(strip $(FOAM_MODULE_LIBBIN)))
    FOAM_MODULE_LIBBIN = $(FOAM_USER_LIBBIN)
endif

/* Capture absolute source directory at compile time */
SOLVER_SOURCE_DIR := $(abspath $(dir $(lastword $(MAKEFILE_LIST)))/../..)

/* Python */
PY_INCS := \
    -Wno-old-style-cast \
    -I$(PYTHON_INCLUDE_PATH) \
    -I$(NUMPY_INCLUDE_PATH) \
    -L$(PYTHON_LIB_PATH)

PY_LIBS := \
    -$(PYTHON_LIB_NAME)

/* HDF5 - from conda environment */
HDF5_INCS := \
    -I$(PYTHON_LIB_PATH)/../include

HDF5_LIBS := \
    -L$(PYTHON_LIB_PATH) \
    -lhdf5

#ifdef OPENFOAM
/* openfoam.com */

TRANSPORT_INCS := \
    -I$(LIB_SRC)/transportModels \
    -I$(LIB_SRC)/TurbulenceModels/turbulenceModels/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/compressible/lnInclude

TRANSPORT_LIBS := \
    -lturbulenceModels \
    -lcompressibleTransportModels

#else
/* openfoam.org */

TRANSPORT_INCS := \
    -I$(LIB_SRC)/MomentumTransportModels/momentumTransportModels/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/compressible/lnInclude

TRANSPORT_LIBS := \
    -lmomentumTransportModels \
    -lfluidThermoMomentumTransportModels

#endif

EXE_INC = \
    -DSOLVER_SOURCE_DIR=\"$(SOLVER_SOURCE_DIR)\" \
    -I. \
    -I$(WM_PROJECT_DIR)/applications/solvers/compressible/rhoPimpleFoam \
    $(TRANSPORT_INCS) \
    -I$(LIB_SRC)/thermophysicalModels/basic/lnInclude \
    -I$(LIB_SRC)/radiationModels/lnInclude \
    -I$(LIB_SRC)/ThermophysicalTransportModels/lnInclude \
    -I$(LIB_SRC)/finiteVolume/cfdTools \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    $(PY_INCS) \
    $(HDF5_INCS)

EXE_LIBS = \
    -lfluidThermophysicalModels \
    -lradiationModels \
    -lspecie \
    $(TRANSPORT_LIBS) \
    -lthermophysicalTransportModels \
    -lfiniteVolume \
    -ldynamicFvMesh \
    -ltopoChangerFvMesh \
    -lmeshTools \
    -lsampling \
    -lfvOptions \
    $(HDF5_LIBS) \
    $(PY_LIBS)
